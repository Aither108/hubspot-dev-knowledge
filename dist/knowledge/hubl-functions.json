{
    "category": "hubl-functions",
    "description": "HubL built-in functions for HubSpot CMS templates",
    "source": "https://developers.hubspot.com/docs/cms/hubl/functions",
    "notes": [
        "Most data retrieval functions are capped at 10 calls per page/email",
        "CRM functions require password protection or login for standard objects",
        "HubDB functions require Content Hub Professional or Enterprise tier"
    ],
    "functions": [
        {
            "name": "append",
            "syntax": "list.append(item)",
            "params": [
                "item: Any"
            ],
            "returns": "Modified list",
            "description": "Appends an item to a list",
            "example": "{% do numbers.append(4) %}"
        },
        {
            "name": "blog_all_posts_url",
            "syntax": "blog_all_posts_url(selected_blog)",
            "params": [
                "selected_blog: Blog ID or \"default\""
            ],
            "returns": "String (URL)",
            "description": "Returns URL to all posts blog listing page",
            "example": "{{ blog_all_posts_url(\"default\") }}"
        },
        {
            "name": "blog_author_url",
            "syntax": "blog_author_url(selected_blog, author_slug)",
            "params": [
                "selected_blog: Blog ID or \"default\"",
                "author_slug: String"
            ],
            "returns": "String (URL)",
            "description": "Returns URL to an author's listing page",
            "example": "{{ blog_author_url(\"default\", \"brian-halligan\") }}"
        },
        {
            "name": "blog_authors",
            "syntax": "blog_authors(selected_blog, limit)",
            "params": [
                "selected_blog: Blog ID or \"default\"",
                "limit: Integer (max 250)"
            ],
            "returns": "Sequence of author objects",
            "limit": "250 authors max, 10 calls per page/email",
            "description": "Returns all blog authors",
            "example": "{% set authors = blog_authors(\"default\", 250) %}"
        },
        {
            "name": "blog_by_id",
            "syntax": "blog_by_id(selected_blog)",
            "params": [
                "selected_blog: Blog ID or \"default\""
            ],
            "returns": "Blog object",
            "limit": "10 calls per page/email",
            "description": "Returns blog object with absolute_url, html_title, and other properties",
            "example": "{% set blog = blog_by_id(47104297) %}"
        },
        {
            "name": "blog_page_link",
            "syntax": "blog_page_link(page)",
            "params": [
                "page: Number or HubL variable"
            ],
            "returns": "String (URL)",
            "description": "Returns paginated URL for blog listing",
            "example": "{{ blog_page_link(7) }}"
        },
        {
            "name": "blog_popular_posts",
            "syntax": "blog_popular_posts(selected_blog, limit, tag_slug, time_frame, logical_operator)",
            "params": [
                "selected_blog: Blog ID or \"default\"",
                "limit: Integer (max 200)",
                "tag_slug: Array (optional)",
                "time_frame: popular_all_time|popular_past_year|popular_past_six_months|popular_past_month",
                "logical_operator: AND|OR (optional)"
            ],
            "returns": "Sequence of post objects",
            "limit": "200 posts, 10 calls per page/email",
            "description": "Returns popular blog posts",
            "example": "{% set posts = blog_popular_posts(\"default\", 5, [\"marketing-tips\"], \"popular_past_month\") %}"
        },
        {
            "name": "blog_post_archive_url",
            "syntax": "blog_post_archive_url(selected_blog, year, month, day)",
            "params": [
                "selected_blog (required)",
                "year (required)",
                "month (optional)",
                "day (optional)"
            ],
            "returns": "String (URL)",
            "description": "Returns archive page URL for specified date",
            "example": "{{ blog_post_archive_url(\"default\", 2017, 7, 5) }}"
        },
        {
            "name": "blog_recent_author_posts",
            "syntax": "blog_recent_author_posts(selected_blog, author_slug, limit)",
            "params": [
                "selected_blog",
                "author_slug: String",
                "limit: Integer"
            ],
            "returns": "Sequence of posts",
            "limit": "200 posts, 10 calls per page/email",
            "description": "Returns most recent posts by a specific author",
            "example": "{% set posts = blog_recent_author_posts(\"default\", content.blog_post_author.slug, 5) %}"
        },
        {
            "name": "blog_recent_posts",
            "syntax": "blog_recent_posts(selected_blog, limit)",
            "params": [
                "selected_blog: Blog ID or \"default\"",
                "limit: Integer (max 200)"
            ],
            "returns": "Sequence of post objects",
            "limit": "10 calls per page/email",
            "description": "Returns most recent blog posts",
            "example": "{% set posts = blog_recent_posts(\"default\", 5) %}"
        },
        {
            "name": "blog_recent_tag_posts",
            "syntax": "blog_recent_tag_posts(selected_blog, tag_slug, limit, logical_operator)",
            "params": [
                "selected_blog",
                "tag_slug: String or Array",
                "limit: Integer",
                "logical_operator: AND|OR (optional)"
            ],
            "returns": "Sequence of posts",
            "limit": "100 posts, 10 calls per page/email",
            "description": "Returns recent posts matching specified tag(s)",
            "example": "{% set posts = blog_recent_tag_posts(\"default\", [\"marketing\", \"fun\"], 3, \"AND\") %}"
        },
        {
            "name": "blog_tag_url",
            "syntax": "blog_tag_url(selected_blog, tag_slug)",
            "params": [
                "selected_blog",
                "tag_slug: String"
            ],
            "returns": "String (URL)",
            "description": "Returns URL to a tag's listing page",
            "example": "{{ blog_tag_url(\"default\", \"inbound-marketing\") }}"
        },
        {
            "name": "blog_tags",
            "syntax": "blog_tags(selected_blog, limit)",
            "params": [
                "selected_blog",
                "limit: Integer (max 250)"
            ],
            "returns": "Sequence of tag objects (sorted by post count)",
            "limit": "250 tags, 10 calls per page/email",
            "description": "Returns all blog tags",
            "example": "{% set tags = blog_tags(\"default\", 250) %}"
        },
        {
            "name": "blog_total_post_count",
            "syntax": "blog_total_post_count(selected_blog)",
            "params": [
                "selected_blog (optional, defaults to default blog)"
            ],
            "returns": "Integer",
            "limit": "10 calls per page/email",
            "description": "Returns total count of published blog posts",
            "example": "{{ blog_total_post_count(359485112) }}"
        },
        {
            "name": "clear",
            "syntax": "list.clear()",
            "params": [],
            "returns": "Nothing",
            "description": "Empties a list",
            "example": "{% do words.clear() %}"
        },
        {
            "name": "color_contrast",
            "syntax": "color_contrast(color_1, color_2, rating)",
            "params": [
                "color_1: Color (hex)",
                "color_2: Color (hex)",
                "rating: AA|AAA (optional)"
            ],
            "returns": "Boolean",
            "description": "Tests if two colors meet WCAG contrast ratio",
            "example": "{{ color_contrast('#FFFFFF', '#273749') }}"
        },
        {
            "name": "color_variant",
            "syntax": "color_variant(base_color, brightness_offset)",
            "params": [
                "base_color: HEX String",
                "brightness_offset: Integer (-255 to 255)"
            ],
            "returns": "HEX String",
            "description": "Returns a lighter or darker variant of a hex color",
            "example": "{{ color_variant(\"#3A539B\", -80) }}"
        },
        {
            "name": "content_by_id",
            "syntax": "content_by_id(id)",
            "params": [
                "id: Numeric content ID"
            ],
            "returns": "Content object (page, blog post)",
            "limit": "10 calls per page, 20 per email",
            "description": "Returns a content object by its ID",
            "example": "{% set content = content_by_id(4715624297) %}"
        },
        {
            "name": "content_by_ids",
            "syntax": "content_by_ids(ids)",
            "params": [
                "ids: List of IDs (max 100)"
            ],
            "returns": "Dictionary of content objects",
            "limit": "10 calls per page/email",
            "description": "Returns multiple content objects by their IDs",
            "example": "{% set contents = content_by_ids([4715624297, 4712623297]) %}"
        },
        {
            "name": "crm_associations",
            "syntax": "crm_associations(id, association_category, association_type_id, query, properties, formatting)",
            "params": [
                "id: Record ID",
                "association_category: HUBSPOT_DEFINED|USER_DEFINED|INTEGRATOR_DEFINED",
                "association_type_id: Integer",
                "query: String with filters",
                "properties: String (comma-separated)",
                "formatting: Boolean (optional)"
            ],
            "returns": "Dict with has_more, offset, total, results array",
            "limit": "10 calls per page/email, max 100 objects per call",
            "description": "Returns CRM records associated with a given record",
            "example": "{% set contacts = crm_associations(847943847, \"HUBSPOT_DEFINED\", 2, \"limit=3\") %}"
        },
        {
            "name": "crm_object",
            "syntax": "crm_object(object_type, query, properties, formatting)",
            "params": [
                "object_type: String",
                "query: String",
                "properties: String (optional)",
                "formatting: Boolean (optional)"
            ],
            "returns": "Single CRM record as dictionary",
            "limit": "10 calls per page max",
            "description": "Returns a single CRM record matching the query",
            "example": "{% set contact = crm_object(\"contact\", \"email=contact@company.com\") %}"
        },
        {
            "name": "crm_objects",
            "syntax": "crm_objects(object_type, query, properties, formatting)",
            "params": [
                "object_type: String (required)",
                "query: String",
                "properties: String",
                "formatting: Boolean"
            ],
            "returns": "Dict with has_more, offset, total, results array",
            "limit": "10 calls per page/email, max 100 objects",
            "description": "Returns multiple CRM records matching the query",
            "example": "{% set objects = crm_objects(\"contact\", \"firstname=Bob&limit=3\") %}"
        },
        {
            "name": "crm_property_definition",
            "syntax": "crm_property_definition(object_type, property_name)",
            "params": [
                "object_type: String",
                "property_name: String"
            ],
            "returns": "Property definition object (label, type, etc.)",
            "description": "Returns the definition of a single CRM property",
            "example": "{% set prop = crm_property_definition(\"contact\", \"firstname\") %}"
        },
        {
            "name": "crm_property_definitions",
            "syntax": "crm_property_definitions(object_type, property_name)",
            "params": [
                "object_type: String",
                "property_name: String (optional)"
            ],
            "returns": "Map of property definitions",
            "description": "Returns definitions of CRM properties",
            "example": "{% set props = crm_property_definitions(\"contact\", \"firstname,lastname\") %}"
        },
        {
            "name": "cta",
            "syntax": "cta(guid, align_opt)",
            "params": [
                "guid: String",
                "align_opt: justifyleft|justifycenter|justifyright|justifyfull (optional)"
            ],
            "returns": "Rendered CTA HTML",
            "limit": "10 calls per page/email",
            "description": "Renders a HubSpot CTA button",
            "example": "{{ cta(\"ccd39b7c-ae18-4c4e-98ee-547069bfbc5b\", \"justifycenter\") }}"
        },
        {
            "name": "file_by_id",
            "syntax": "file_by_id(file_id)",
            "params": [
                "file_id: Number"
            ],
            "returns": "File metadata object (friendlyUrl, name, url)",
            "limit": "10 calls per page/email",
            "description": "Returns file metadata by ID",
            "example": "{% set file = file_by_id(123) %}"
        },
        {
            "name": "files_by_ids",
            "syntax": "files_by_ids(file_ids)",
            "params": [
                "file_ids: Array (max 100)"
            ],
            "returns": "Array of file metadata objects",
            "limit": "10 calls per page/email",
            "description": "Returns multiple file metadata objects by ID",
            "example": "{% set files = files_by_ids([123, 456]) %}"
        },
        {
            "name": "flag_content_for_access_check",
            "syntax": "flag_content_for_access_check(id)",
            "params": [
                "id: Content ID"
            ],
            "returns": "HTML attribute string",
            "description": "Returns hs-member-content-access attribute for membership gating",
            "example": "<article {{ flag_content_for_access_check(content.id) }} >"
        },
        {
            "name": "follow_me_links",
            "syntax": "follow_me_links()",
            "params": [],
            "returns": "Array of social media link objects",
            "description": "Returns social media follow links configured in account settings",
            "example": "{% set fm = follow_me_links() %}"
        },
        {
            "name": "format_address",
            "syntax": "format_address(locale, address_dict)",
            "params": [
                "locale: String",
                "address_dict with keys: address, address2, city, state, country, zip"
            ],
            "returns": "Formatted address string",
            "description": "Formats an address for a given locale",
            "example": "{{ format_address('en-us', {address: \"25 First Street\", city: \"Cambridge\"}) }}"
        },
        {
            "name": "format_datetime",
            "syntax": "format_datetime(date_object, format, timeZone, locale)",
            "params": [
                "date_object",
                "format: short|medium|long|full or Unicode LDML pattern",
                "timeZone: IANA TZDB",
                "locale: String"
            ],
            "returns": "Formatted datetime string",
            "description": "Formats a datetime object into a readable string",
            "example": "{{ format_datetime(content.publish_date, \"short\", \"America/New_York\", \"en\") }}"
        },
        {
            "name": "get_asset_url",
            "syntax": "get_asset_url(path)",
            "params": [
                "path: String (design manager file path)"
            ],
            "returns": "Public URL string",
            "description": "Returns the public CDN URL for a design manager asset",
            "example": "{{ get_asset_url(\"/custom/styles/style.css\") }}"
        },
        {
            "name": "get_public_template_url_by_id",
            "syntax": "get_public_template_url_by_id(template_id)",
            "params": [
                "template_id: ID"
            ],
            "returns": "Public URL string",
            "description": "Returns the public URL for a template or file by ID",
            "example": "{{ get_public_template_url_by_id(\"2778457004\") }}"
        },
        {
            "name": "hubdb_table",
            "syntax": "hubdb_table(table_id)",
            "params": [
                "table_id: String (ID or name)"
            ],
            "returns": "Table metadata object (name, columns, created_at, published_at, updated_at, row_count)",
            "limit": "10 calls per page/email. Requires HubDB Professional+.",
            "description": "Returns HubDB table metadata",
            "example": "{% set table = hubdb_table(1548215) %}"
        },
        {
            "name": "hubdb_table_column",
            "syntax": "hubdb_table_column(table_id, column)",
            "params": [
                "table_id: String",
                "column: String (ID or name, case-insensitive)"
            ],
            "returns": "Column metadata (name, label, type, options, foreignIds)",
            "requires": "HubDB Professional+",
            "description": "Returns metadata for a specific HubDB table column",
            "example": "{% set col = hubdb_table_column(123456, 6) %}"
        },
        {
            "name": "hubdb_table_row",
            "syntax": "hubdb_table_row(table_id, row_id)",
            "params": [
                "table_id: String",
                "row_id: Integer"
            ],
            "returns": "Row object accessible via column name attributes",
            "limit": "10 calls per page/email. Requires HubDB Professional+.",
            "description": "Returns a single HubDB row by ID",
            "example": "{% set row = hubdb_table_row(1548264, 6726439331) %}"
        },
        {
            "name": "hubdb_table_rows",
            "syntax": "hubdb_table_rows(table_id, query)",
            "params": [
                "table_id: String",
                "query: String (filters, operators, limit, offset, orderBy)"
            ],
            "returns": "Rows matching query",
            "limit": "10 calls per page/email, default 1000 rows. Requires HubDB Professional+.",
            "description": "Returns HubDB rows matching a filter query",
            "example": "{% for row in hubdb_table_rows(1546258, \"years__gt=3&limit=1500\") %}"
        },
        {
            "name": "include_default_custom_css",
            "syntax": "include_default_custom_css(True)",
            "params": [
                "Boolean (must be True)"
            ],
            "returns": "Link tag referencing primary CSS file",
            "description": "Includes the account's primary CSS file",
            "example": "{{ include_default_custom_css(True) }}"
        },
        {
            "name": "load_translations",
            "syntax": "load_translations(path, language_code, language_code_fallback)",
            "params": [
                "path: String (to _locales folder)",
                "language_code: String",
                "language_code_fallback: String"
            ],
            "returns": "Map of translation values",
            "description": "Loads translation strings for multi-language templates",
            "example": "{% set translations = load_translations('../_locales', 'fr', 'en') %}"
        },
        {
            "name": "locale_name",
            "syntax": "locale_name(language_code, target_language_code)",
            "params": [
                "language_code: String",
                "target_language_code: String (optional)"
            ],
            "returns": "Human-readable locale string",
            "description": "Returns human-readable name of a locale",
            "example": "{{ locale_name(\"es\", \"en\") }}"
        },
        {
            "name": "menu",
            "syntax": "menu(menu_id, root_type, root_key)",
            "params": [
                "menu_id: numeric ID or \"default\" (required)",
                "root_type: site_root|top_parent|parent|page_name|page_id|breadcrumb",
                "root_key: String (optional)"
            ],
            "returns": "Menu node object with children property",
            "limit": "10 calls per page/email",
            "description": "Returns a menu object for rendering navigation",
            "example": "{% set node = menu(987) %}"
        },
        {
            "name": "module_asset_url",
            "syntax": "module_asset_url(name)",
            "params": [
                "name: String (asset file name)"
            ],
            "returns": "Asset URL string",
            "description": "Returns CDN URL for a file inside the current module folder",
            "example": "{{ module_asset_url(\"smile.jpg\") }}"
        },
        {
            "name": "namespace",
            "syntax": "namespace(dictionary, kwargs)",
            "params": [
                "dictionary: Map (optional)",
                "kwargs: keyword arguments (optional)"
            ],
            "returns": "Namespace object",
            "description": "Creates a namespace object that can be mutated inside loops",
            "example": "{% set ns = namespace(name: \"item\", price: \"100\") %}"
        },
        {
            "name": "oembed",
            "syntax": "oembed(request)",
            "params": [
                "request: Object with url key"
            ],
            "returns": "OEmbed data dictionary",
            "note": "Works in emails only",
            "description": "Returns OEmbed data for embedding external content",
            "example": "{{ oembed({url: \"https://www.youtube.com/watch?v=KqpFNtbEOh8\"}) }}"
        },
