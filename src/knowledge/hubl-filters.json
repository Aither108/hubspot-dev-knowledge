{
  "category": "hubl-filters",
  "description": "HubL filters for transforming variable output in HubSpot CMS templates",
  "source": "https://developers.hubspot.com/docs/cms/hubl/filters",
  "usage": "Filters use pipe syntax: {{ variable|filtername(params) }}",
  "filters": [
    { "name": "abs", "syntax": "|abs", "returns": "Number", "description": "Returns absolute value", "example": "{{ -53|abs }} → 53" },
    { "name": "add", "syntax": "|add(n)", "params": ["addend: Number"], "returns": "Number", "description": "Adds a number", "example": "{{ 40|add(13) }} → 53" },
    { "name": "attr", "syntax": "|attr(\"name\")", "params": ["attribute_name: String"], "returns": "Variable", "description": "Returns attribute of an object", "example": "{{ content|attr(\"absolute_url\") }}" },
    { "name": "batch", "syntax": "|batch(n, fill)", "params": ["linecount: Number", "fill_with: String"], "returns": "List", "description": "Groups a sequence into batches of n items" },
    { "name": "between_times", "syntax": "|between_times(end, unit)", "params": ["end: datetime", "timeunit: String"], "returns": "Number", "description": "Returns time difference between two dates", "example": "{{ begin|between_times(end, \"days\") }}" },
    { "name": "bool", "syntax": "|bool", "returns": "Boolean", "description": "Converts value to boolean", "example": "{{ \"true\"|bool }} → true" },
    { "name": "capitalize", "syntax": "|capitalize", "returns": "String", "description": "Capitalizes first character", "example": "{{ \"hello\"|capitalize }} → \"Hello\"" },
    { "name": "center", "syntax": "|center(width)", "params": ["width: Number"], "returns": "String", "description": "Centers text within given width using whitespace" },
    { "name": "convert_rgb", "syntax": "|convert_rgb", "returns": "String", "description": "Converts hex color to RGB string", "example": "{{ \"#FFFFFF\"|convert_rgb }} → \"255, 255, 255\"" },
    { "name": "cut", "syntax": "|cut(str)", "params": ["characters_to_cut: String"], "returns": "String", "description": "Removes specified substring", "example": "{{ \"Hello world.\"|cut(\" world\") }} → \"Hello.\"" },
    { "name": "default", "syntax": "|default(val, bool)", "params": ["default_value", "truthy: Boolean"], "returns": "Variable", "description": "Returns default if variable is undefined or falsy", "example": "{{ undefined|default(\"N/A\") }}" },
    { "name": "dictsort", "syntax": "|dictsort(case, by)", "params": ["case_sensitive: Boolean", "sort_by: key|value"], "returns": "List", "description": "Sorts a dictionary by key or value" },
    { "name": "difference", "syntax": "|difference(list)", "params": ["list: Array"], "returns": "Array", "description": "Returns items in first list not in second", "example": "{{ [1,2,3]|difference([2,3,4]) }} → [1]" },
    { "name": "divide", "syntax": "|divide(n)", "params": ["divisor: Number"], "returns": "Number", "description": "Divides value by n", "example": "{{ 106|divide(2) }} → 53" },
    { "name": "divisible", "syntax": "|divisible(n)", "params": ["divisor: Number"], "returns": "Boolean", "description": "Tests if value is divisible by n", "example": "{{ 10|divisible(2) }} → true" },
    { "name": "escape_html", "syntax": "|escape_html", "returns": "String", "description": "Escapes HTML special characters", "example": "{{ \"<div>\"|escape_html }} → \"&lt;div&gt;\"" },
    { "name": "escape_attr", "syntax": "|escape_attr", "returns": "String", "description": "Escapes HTML attribute values" },
    { "name": "escape_jinjava", "syntax": "|escape_jinjava", "returns": "String", "description": "Escapes { and } characters for HubL" },
    { "name": "escape_js", "syntax": "|escape_js", "returns": "String", "description": "Escapes string for safe JavaScript usage" },
    { "name": "escape_url", "syntax": "|escape_url", "returns": "String", "description": "URL-encodes the value" },
    { "name": "escapejson", "syntax": "|escapejson", "returns": "String", "description": "Escapes string for safe JSON embedding" },
    { "name": "filesizeformat", "syntax": "|filesizeformat(binary)", "params": ["binary: Boolean"], "returns": "String", "description": "Formats filesize in human-readable form", "example": "{{ 10000|filesizeformat(binary=true) }}" },
    { "name": "first", "syntax": "|first", "returns": "Variable", "description": "Returns first item of a sequence", "example": "{{ list|first }}" },
    { "name": "float", "syntax": "|float(default)", "params": ["default: Number"], "returns": "Float", "description": "Converts value to float", "example": "{{ \"25\"|float + 17 }} → 42.0" },
    { "name": "format", "syntax": "|format(arg1, arg2)", "returns": "String", "description": "Applies printf-style formatting", "example": "{{ \"Hi %s\"|format(name) }}" },
    { "name": "format_currency_value", "syntax": "|format_currency_value(params)", "params": ["locale: String", "currency: String", "minDecimalDigits: Number", "maxDecimalDigits: Number"], "returns": "String", "description": "Formats a number as currency", "example": "{{ 100|format_currency_value(locale='en-GB', currency='EUR') }}" },
    { "name": "format_date", "syntax": "|format_date(fmt, tz, locale)", "params": ["format: String", "timeZone: String", "locale: String"], "returns": "String", "description": "Formats a date value", "example": "{{ date|format_date('long') }}" },
    { "name": "format_datetime", "syntax": "|format_datetime(fmt, tz, locale)", "params": ["format: String", "timeZone: String", "locale: String"], "returns": "String", "description": "Formats a datetime value. Formats: short, medium, long, full or Unicode LDML pattern.", "example": "{{ date|format_datetime('medium') }}" },
    { "name": "format_number", "syntax": "|format_number(locale, max)", "params": ["locale: String", "maxDecimalDigits: Number"], "returns": "String", "description": "Formats a number for locale", "example": "{{ 1000|format_number('en-US') }}" },
    { "name": "format_time", "syntax": "|format_time(fmt, tz, locale)", "params": ["format: String", "timeZone: String", "locale: String"], "returns": "String", "description": "Formats a time value" },
    { "name": "fromjson", "syntax": "|fromjson", "returns": "Object", "description": "Parses JSON string into object", "example": "{{ jsonstring|fromjson }}" },
    { "name": "groupby", "syntax": "|groupby(\"attr\")", "params": ["attribute: String"], "returns": "List", "description": "Groups a sequence by an attribute" },
    { "name": "indent", "syntax": "|indent(width, first)", "params": ["width: Number", "indent-first: Boolean"], "returns": "String", "description": "Indents text by given number of spaces" },
    { "name": "int", "syntax": "|int(default)", "params": ["default: Number"], "returns": "Integer", "description": "Converts value to integer", "example": "{{ \"25\"|int + 17 }} → 42" },
    { "name": "intersect", "syntax": "|intersect(list)", "params": ["list: Array"], "returns": "Array", "description": "Returns items present in both lists", "example": "{{ [1,2,3]|intersect([2,3,4]) }} → [2,3]" },
    { "name": "ipaddr", "syntax": "|ipaddr", "returns": "Boolean", "description": "Tests if value is a valid IP address" },
    { "name": "join", "syntax": "|join(delim, attr)", "params": ["delimiter: String", "attribute: Variable"], "returns": "String", "description": "Joins sequence with delimiter", "example": "{{ list|join(\", \") }}" },
    { "name": "last", "syntax": "|last", "returns": "Variable", "description": "Returns last item of a sequence" },
    { "name": "length", "syntax": "|length", "returns": "Number", "description": "Returns length of string or sequence", "example": "{{ list|length }}" },
    { "name": "list", "syntax": "|list", "returns": "Array", "description": "Converts value to a list" },
    { "name": "lower", "syntax": "|lower", "returns": "String", "description": "Converts string to lowercase", "example": "{{ \"HELLO\"|lower }} → \"hello\"" },
    { "name": "map", "syntax": "|map(\"filter\")", "params": ["filter: String"], "returns": "Array", "description": "Applies a filter to each item in sequence", "example": "{{ list|map(\"upper\") }}" },
    { "name": "md5", "syntax": "|md5", "returns": "String", "description": "Returns MD5 hash of the value" },
    { "name": "minus_time", "syntax": "|minus_time(diff, unit)", "params": ["diff: Number", "timeunit: String"], "returns": "datetime", "description": "Subtracts time from a datetime" },
    { "name": "multiply", "syntax": "|multiply(n)", "params": ["multiplier: Number"], "returns": "Number", "description": "Multiplies value by n", "example": "{{ 20|multiply(3) }} → 60" },
    { "name": "plus_time", "syntax": "|plus_time(diff, unit)", "params": ["diff: Number", "timeunit: String"], "returns": "datetime", "description": "Adds time to a datetime" },
    { "name": "pprint", "syntax": "|pprint", "returns": "String", "description": "Pretty-prints variable for debugging", "example": "{{ var|pprint }}" },
    { "name": "random", "syntax": "|random", "returns": "Variable", "description": "Returns a random item (prerendered periodically)" },
    { "name": "regex_replace", "syntax": "|regex_replace(pattern, repl)", "params": ["pattern: String", "replacement: String"], "returns": "String", "description": "Replaces regex matches", "example": "{{ \"abc-123\"|regex_replace(\"[^a-z]\", \"\") }}" },
    { "name": "reject", "syntax": "|reject(\"test\")", "params": ["exp_text: String"], "returns": "Array", "description": "Filters sequence using expression test" },
    { "name": "rejectattr", "syntax": "|rejectattr(\"attr\", \"test\")", "params": ["attribute_name: String", "exp_test: String"], "returns": "Array", "description": "Rejects items by attribute test" },
    { "name": "render", "syntax": "|render", "returns": "String", "description": "Forces early rendering of HubL content" },
    { "name": "replace", "syntax": "|replace(old, new, count)", "params": ["old: String", "new: String", "count: Number"], "returns": "String", "description": "Replaces occurrences of a substring", "example": "{{ \"hello\"|replace(\"l\", \"x\") }}" },
    { "name": "reverse", "syntax": "|reverse", "returns": "Iterator", "description": "Reverses a sequence" },
    { "name": "round", "syntax": "|round(precision, method)", "params": ["precision: Number", "rounding_method: String"], "returns": "Number", "description": "Rounds a number", "example": "{{ 52.5|round }} → 53" },
    { "name": "safe", "syntax": "|safe", "returns": "String", "description": "Marks content as safe (not escaped)" },
    { "name": "sanitize_html", "syntax": "|sanitize_html(type)", "params": ["tag_types: FORMATTING|BLOCKS|STYLES|LINKS|TABLES|IMAGES"], "returns": "String", "description": "Strips unsafe HTML tags by category" },
    { "name": "select", "syntax": "|select(\"test\")", "params": ["exp_text: String"], "returns": "Array", "description": "Selects items using expression test" },
    { "name": "selectattr", "syntax": "|selectattr(\"attr\", \"test\", val)", "params": ["attribute_name: String", "exp_test: String", "val"], "returns": "Array", "description": "Selects items by attribute test" },
    { "name": "shuffle", "syntax": "|shuffle", "returns": "Iterator", "description": "Randomizes sequence order (prerendered)" },
    { "name": "slice", "syntax": "|slice(count, fill)", "params": ["slices: Number", "filler: String"], "returns": "List", "description": "Slices sequence into n sublists" },
    { "name": "sort", "syntax": "|sort(reverse, case, attr)", "params": ["reverse: Boolean", "case_sensitive: Boolean", "attribute: String"], "returns": "Array", "description": "Sorts a sequence", "example": "{{ list|sort(False, False, \"name\") }}" },
    { "name": "split", "syntax": "|split(sep, limit)", "params": ["character_to_split_by: String", "number_of_splits: Number"], "returns": "Array", "description": "Splits string into array", "example": "{{ \"a;b;c\"|split(\";\") }}" },
    { "name": "string", "syntax": "|string", "returns": "String", "description": "Converts value to string", "example": "{{ 45|string }}" },
    { "name": "striptags", "syntax": "|striptags", "returns": "String", "description": "Removes HTML tags from string", "example": "{{ \"<p>text</p>\"|striptags }} → \"text\"" },
    { "name": "strtodate", "syntax": "|strtodate(fmt)", "params": ["dateFormat: String"], "returns": "date", "description": "Converts string to date object", "example": "{{ \"3/3/21\"|strtodate('M/d/yy') }}" },
    { "name": "strtotime", "syntax": "|strtotime(fmt)", "params": ["datetimeFormat: String"], "returns": "datetime", "description": "Converts string to datetime object" },
    { "name": "sum", "syntax": "|sum(attr, default)", "params": ["attribute: String", "return_if_nothing"], "returns": "Number", "description": "Sums values in a sequence" },
    { "name": "symmetric_difference", "syntax": "|symmetric_difference(list)", "params": ["list: Array"], "returns": "Array", "description": "Returns items in either list but not both" },
    { "name": "title", "syntax": "|title", "returns": "String", "description": "Title-cases the string", "example": "{{ \"hello world\"|title }} → \"Hello World\"" },
    { "name": "tojson", "syntax": "|tojson", "returns": "String", "description": "Converts object to JSON string" },
    { "name": "trim", "syntax": "|trim", "returns": "String", "description": "Removes leading and trailing whitespace" },
    { "name": "truncate", "syntax": "|truncate(len, break, end)", "params": ["number_of_characters: Number", "breakword: Boolean", "end: String"], "returns": "String", "description": "Truncates string with ellipsis" },
    { "name": "truncatehtml", "syntax": "|truncatehtml(len, end, break)", "params": ["number_of_characters: Number", "end: String", "breakword: Boolean"], "returns": "String", "description": "Truncates respecting HTML tag structure" },
    { "name": "unescape_html", "syntax": "|unescape_html", "returns": "String", "description": "Decodes HTML entities" },
    { "name": "union", "syntax": "|union(list)", "params": ["list: Array"], "returns": "Array", "description": "Returns unique items from both lists", "example": "{{ [1,2,3]|union([3,4,5]) }} → [1,2,3,4,5]" },
    { "name": "unique", "syntax": "|unique(attr)", "params": ["attr: String"], "returns": "Array", "description": "Removes duplicate items from sequence" },
    { "name": "unixtimestamp", "syntax": "|unixtimestamp", "returns": "Number", "description": "Converts datetime to Unix timestamp" },
    { "name": "upper", "syntax": "|upper", "returns": "String", "description": "Converts string to uppercase", "example": "{{ \"hello\"|upper }} → \"HELLO\"" },
    { "name": "urlencode", "syntax": "|urlencode", "returns": "String", "description": "URL-encodes the string" },
    { "name": "urldecode", "syntax": "|urldecode", "returns": "String", "description": "Decodes a URL-encoded string" },
    { "name": "urlize", "syntax": "|urlize(len, nofollow, target)", "params": ["shorten_text: Number", "no_follow: Boolean", "target: String"], "returns": "String", "description": "Converts plain URLs to anchor tags" },
    { "name": "wordcount", "syntax": "|wordcount", "returns": "Number", "description": "Returns word count of string", "example": "{{ \"hello world\"|wordcount }} → 2" },
    { "name": "wordwrap", "syntax": "|wordwrap(chars)", "params": ["character_count: Number"], "returns": "String", "description": "Wraps text at given character count" },
    { "name": "xmlattr", "syntax": "|xmlattr(autospace)", "params": ["autospace: Boolean"], "returns": "String", "description": "Creates XML attribute string from dictionary" }
  ]
}
